[Unit]
Description=Sensor Dashboard Flask Server
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/weather-station
ExecStart=/home/pi/weather-station/venv/bin/gunicorn -w 4 -b 0.0.0.0:5000 --access-logfile /home/pi/weather-station/access.log --error-logfile /home/pi/weather-station/error.log sensor_server:app
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
